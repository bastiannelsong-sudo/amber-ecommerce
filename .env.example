# API Configuration
# Backend NestJS — server-only. NUNCA agregar prefijo NEXT_PUBLIC_*.
# En prod: hostname interno (service discovery AWS / docker network).
INTERNAL_API_URL=http://localhost:3000

# URL pública del ecommerce (OG, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Session — cookie httpOnly firmada (mínimo 32 chars aleatorios)
SESSION_SECRET=change-me-in-production-at-least-32-chars

# Google OAuth (público por diseño — es un client identifier)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ReportPortal (solo para test:e2e:rp y test:rp)
RP_API_KEY=
RP_ENDPOINT=http://localhost:8080/api/v2
RP_PROJECT=amber
RP_LAUNCH=amber-ecommerce-e2e
